    {
      "id": "RPprx3pq-ffBFWsL2_i4e",
      "type": "rectangle",
      "x": -1681.1448794015537,
      "y": 6734.8116263455795,
      "width": 2446.6945497216257,
      "height": 1605.0552666125857,
