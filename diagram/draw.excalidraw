      "text": "the undelying ktable will buffer events\nmeaning it puts data into the cache buffer\nand every 30  sec pushes it to the topic,\nremove this cache!",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "the undelying ktable will buffer events\nmeaning it puts data into the cache buffer\nand every 30  sec pushes it to the topic,\nremove this cache!",
      "autoResize": true,
      "lineHeight": 1.25
    }
