    {
      "id": "OcrNVZcrgy-4ea-z0ojBS",
      "type": "text",
      "x": 2857.5238601976216,
      "y": -9.275133336231988,
      "width": 1108.6500244140625,
      "height": 623.373451769859,
      "angle": 0,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cRaA",
      "roundness": null,
      "seed": 461915500,
      "version": 1332,
      "versionNonce": 643733270,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768568188278,
      "link": null,
      "locked": false,
      "text": "Other considerations\n ALL messages will use PROTOBUF format.\n - much faster than other compared formats \n Will use lz4 compression for Kafka messages \n - according to the docs they say it's the best for performance\n - lower memery footprint \n Do NOT touch the Kafka segment size\n   -> it will lead to more file creation/deletion and strain the brokers and lower throughput \n   -> keep the default 1GB size for a segment\n Will use virtual threads for processing the batches \n  - most of the processing requires network I/O and useless waiting \n  - virtual threads are ideal for this\n Will not use \"string\" for decimal numbers in protocol\n  - serializing and deserializing numbers is faster than strings\n  - instead will move their decimal point by multiplying by 10^(scale)\n  - ex: 10,0001 -> 10,0001 * 10^4 -> 100001 -> put this in the message along with scale = 4\n  - the consumer will have to know to divide by 10^8 to get the original value\n\noverall these optimizations reduce the binance event to ~125 bytes!\n",
      "fontSize": 24.934938070794363,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Other considerations\n ALL messages will use PROTOBUF format.\n - much faster than other compared formats \n Will use lz4 compression for Kafka messages \n - according to the docs they say it's the best for performance\n - lower memery footprint \n Do NOT touch the Kafka segment size\n   -> it will lead to more file creation/deletion and strain the brokers and lower throughput \n   -> keep the default 1GB size for a segment\n Will use virtual threads for processing the batches \n  - most of the processing requires network I/O and useless waiting \n  - virtual threads are ideal for this\n Will not use \"string\" for decimal numbers in protocol\n  - serializing and deserializing numbers is faster than strings\n  - instead will move their decimal point by multiplying by 10^(scale)\n  - ex: 10,0001 -> 10,0001 * 10^4 -> 100001 -> put this in the message along with scale = 4\n  - the consumer will have to know to divide by 10^8 to get the original value\n\noverall these optimizations reduce the binance event to ~125 bytes!\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
