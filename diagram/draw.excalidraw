    {
      "id": "5X3IZFILf2BDJ1lZyo99t",
      "type": "text",
      "x": 2807.6155608318213,
      "y": -486.17593146528645,
      "width": 629.3235473632812,
      "height": 350,
      "angle": 0,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cRZs",
      "roundness": null,
      "seed": 156099924,
      "version": 628,
      "versionNonce": 464451542,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768568188278,
      "link": null,
      "locked": false,
      "text": "\nNo TTL, new price replaces \nthe old one. If we have TTL and \nprice of pair happens rarely that could lead to \nnot having any price for a given pair.\n\nMode:\n\"arbitrage:BTC/USDT\" -> {\n  binance: {price: 45000, volume: 1000, timestamp: 123456},\n  coinbase: {price: 45100, volume: 800, timestamp: 123457},\n  kraken: {price: 44950, volume: 1200, timestamp: 123458}\n}\nwith this model in one query for a crypto pair we can fetch the \ndata for all exchanges",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nNo TTL, new price replaces \nthe old one. If we have TTL and \nprice of pair happens rarely that could lead to \nnot having any price for a given pair.\n\nMode:\n\"arbitrage:BTC/USDT\" -> {\n  binance: {price: 45000, volume: 1000, timestamp: 123456},\n  coinbase: {price: 45100, volume: 800, timestamp: 123457},\n  kraken: {price: 44950, volume: 1200, timestamp: 123458}\n}\nwith this model in one query for a crypto pair we can fetch the \ndata for all exchanges",
      "autoResize": true,
      "lineHeight": 1.25
    },
