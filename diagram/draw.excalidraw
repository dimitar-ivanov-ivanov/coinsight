      "frameId": null,
      "index": "cRcs",
      "roundness": null,
      "seed": 218919027,
      "version": 1563,
      "versionNonce": 1738129430,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768568188278,
      "link": null,
      "locked": false,
      "text": "Used for storing distributed locks \nfor leader instance.\nNeeded because when we scale to 2nd instance\nwe'll have 2 sockets listening to the same event \nand publish the same event twice to kafka and \nstore it twice in the event storage.\nWe have a job that runs every 5 seconds and \ntries to maintain leadership, if it can't that\nmeans the instance is down and the other\ninstance will take the lock and proceed.\nThen we store the flag in a memory variable, we\nuse it when inputting events and we DON'T CALL\nREDIS for each event.",
      "fontSize": 25.037041558159764,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Used for storing distributed locks \nfor leader instance.\nNeeded because when we scale to 2nd instance\nwe'll have 2 sockets listening to the same event \nand publish the same event twice to kafka and \nstore it twice in the event storage.\nWe have a job that runs every 5 seconds and \ntries to maintain leadership, if it can't that means the instance is down and the other instance will take the lock and proceed.\nThen we store the flag in a memory variable, we use it when inputting events and we DON'T CALL \nREDIS for each event.",
      "autoResize": false,
      "lineHeight": 1.25
    },
