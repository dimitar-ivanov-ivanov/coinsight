      "updated": 1768568188278,
      "link": null,
      "locked": false,
      "text": "Each batch is split up into little\nsub-batches that are taken by virtual threads\nthen they send one HTTP request containing the \nentire batch of events to Vector",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each batch is split up into little\nsub-batches that are taken by virtual threads\nthen they send one HTTP request containing the \nentire batch of events to Vector",
      "autoResize": true,
      "lineHeight": 1.25
    },
